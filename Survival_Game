def determination_game():
    game = {
        "word": "DETERMINATION",
        "guesses": [],
        "attempts": 0,              #Minigame where if you guess correctly you get a buff
        "max_attempts": 7
    }

    while game["attempts"] < game["max_attempts"]:

        print("\nWord:")

        for letter in game["word"]:
            if letter in game["guesses"]:
                print(letter, end=" ")
            else:
                print("_", end=" ")

        print()

        guess = input("Guess a letter: ").upper()

        if guess in game["word"]:
            if guess not in game["guesses"]:
                game["guesses"].append(guess)
                print("Correct!")
        else:
            game["attempts"] += 1           #Takes out one attempt if its wrong
            print("Wrong!")

        if all(letter in game["guesses"] for letter in game["word"]):
            print("You solved the word!")
            return True

    print("You failed!")            #If you fail your health gets taken away by a little
    return False
