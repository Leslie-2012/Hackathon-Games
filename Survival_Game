import random as rn

class Character:
    def __init__(self, name, hp, atk, defense):
        self.name = name
        self.max_hp = hp            #Character stats
        self.hp = hp
        self.atk = atk
        self.defense = defense
    rn
    def attack(self, enemy, damage):
        damage = max(1, damage - enemy.defense)
        enemy.hp -= damage
        if enemy.hp < 0:                #How the enemy takes damage and the player is able to attack back
            enemy.hp = 0
        print(f"{self.name} used an attack!")
        print(f"{enemy.name} took {damage} damage!")

    def heal(self, amount):
        self.hp = min(self.max_hp, self.hp + amount)
        print(f"{self.name} healed {amount} HP!")               #How the Character/Player is able to heal

    def alive(self):
        return self.hp > 0          #Checks if the player is alive
class You(Character):
